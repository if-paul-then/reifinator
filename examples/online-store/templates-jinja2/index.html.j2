{%- set all_entities = entity.all_entities -%}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Online Store - Entity Browser</title>
    <link rel="stylesheet" href="static/styles.css">
</head>
<body>
    <nav>
        <strong>Online Store</strong>
{% for e in all_entities %}
        <a href="{{ e.name }}/index.html">{{ e.name }}</a>
{% endfor %}
    </nav>

    <main>
        <h1>Entity Browser</h1>
        <p>This site was generated by Reifinator from a domain model.</p>

        <table>
            <thead>
                <tr><th>Entity</th><th>Properties</th><th>Relationships</th></tr>
            </thead>
            <tbody>
{% for e in all_entities %}
                <tr>
                    <td><a href="{{ e.name }}/index.html">{{ e.name }}</a></td>
                    <td>{{ e.properties | length }}</td>
                    <td>{{ e.get("relationships", []) | length }}</td>
                </tr>
{% endfor %}
            </tbody>
        </table>
    </main>
</body>
</html>