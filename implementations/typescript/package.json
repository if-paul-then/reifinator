{
  "name": "reifinator",
  "version": "0.1.2",
  "description": "Template-structure-driven code and directory generator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "reify": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "js-yaml": "^4.1.0"
  },
  "optionalDependencies": {
    "eta": "^3.5.0",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/nunjucks": "^3.2.6",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "Paul Steyn <if.paul.then@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/if-paul-then/reifinator.git"
  },
  "homepage": "https://github.com/if-paul-then/reifinator",
  "bugs": {
    "url": "https://github.com/if-paul-then/reifinator/issues"
  },
  "keywords": [
    "code-generation",
    "template",
    "scaffolding",
    "generator",
    "eta",
    "nunjucks"
  ]
}
